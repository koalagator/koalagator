<%= content_for :title, @organization.display_name %>

<div class="single_organization contentbar">
  <a href="#" id="organization_sidebar_toggle" class="expander_toggle">Export or edit this organization...</a>
  <div id="organization_sidebar" class='single_view_right sidebar'>
    <div id='edit_link'>
      <p>
        You can <%= link_to "edit", edit_organization_url(@organization) %>
        or <%= link_to "delete", organization_url(@organization), method: :delete, data: { confirm: "Are you sure?" } %>
        this organization.
      </p>
    </div>
    <hr />
    <p>Download an <%= link_to "iCalendar file", organization_url(@organization, :format => :ics) %> or
    <%= link_to "subscribe to a feed", organization_url(@organization, :format => :ics, :protocol => "webcal") %> of events at this organization.</p>
    <hr />
    <div class="metadata">
      <%= datestamp(@organization) %>
    </div>
  </div>

  <h1><%= @organization.display_name %></h1>
  <p><%= @organization.description %></p>

  <div id='events'>
    <div id='future_events'>
      <h2>Future events we are involved with</h2>
      <%= render partial: 'calagator/events/list', locals: { events: @organization.events.future} %>
    </div>

    <div id='past_events'>
      <h2>Past events that we were involved with</h2>
      <%= render partial: 'calagator/events/list', locals: { events: @organization.events.past } %>
    </div>
  </div>
</div>
